# HTTP / WebSocket server
PORT=4000
HOST=0.0.0.0

# PostgreSQL
DATABASE_URL=postgres://logsentinel:logsentinel@localhost:5432/logsentinel

# Redis
REDIS_URL=redis://localhost:6379

# Ingestion sources (comma-separated list of "type:path")
# Supported types: nginx, ssh, app
LOG_SOURCES=nginx:./sample-logs/nginx-access.log,ssh:./sample-logs/auth.log,app:./sample-logs/app.log

# Ingestion mode: "static" (read once) or "tail" (follow file)
INGEST_MODE=static

# Batch insert tuning
BATCH_SIZE=200
BATCH_INTERVAL_MS=1000

# Sliding window length for realtime metrics (seconds)
METRICS_WINDOW_SEC=60

# GeoIP database path (MaxMind GeoLite2-City.mmdb), optional
GEOIP_DB_PATH=./data/geoip/GeoLite2-City.mmdb

# Alert notification webhook (Discord or Slack), optional
ALERT_WEBHOOK_URL=
ALERT_WEBHOOK_MIN_SEVERITY=critical
ALERT_WEBHOOK_THROTTLE_MS=60000
